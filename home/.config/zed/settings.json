{
  "git_panel": {
    "sort_by_path": true
  },
  "buffer_font_family": ".ZedMono",
  "title_bar": {
    "show_branch_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_user_picture": true,
    "show_sign_in": true,
    "show_menus": false
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "!basedpyright", "..."],
      "format_on_save": "off"
    }
  },
  "vim_mode": true,
  "terminal": {
    "font_size": 12.0,
    "copy_on_select": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false
  },
  "tab_bar": {
    "show": false
  },
  "tabs": {
    "file_icons": false
  },
  "minimap": {
    "show": "never"
  },
  "file_types": {},
  "show_whitespaces": "all",
  "wrap_guides": [80],
  "soft_wrap": "editor_width",
  "ui_font_size": 14,
  "buffer_font_size": 14.0,
  "theme": "One Dark",
  "features": {
    "edit_prediction_provider": "none"
  }
}
